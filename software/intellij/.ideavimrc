""" Map leader to space ---------------------
let mapleader=" "

""" Plugins  --------------------------------
set surround
set multiple-cursors
set commentary
set argtextobj
set textobj-entire

""" Plugin settings -------------------------
let g:argtextobj_pairs="[:],(:),<:>"
""" Common settings -------------------------
set showmode
set so=0
set incsearch
set nu
set visualbell
set noerrorbells
set number relativenumber
set ignorecase smartcase
""" Idea specific settings ------------------
set ideajoin
set ideastatusicon=gray
set idearefactormode=keep
set clipboard+=unnamed
""" Mappings --------------------------------

map rn <Action>(RenameElement)
map <leader>c <Action>(Stop)
map <leader>z <Action>(ToggleDistractionFreeMode)
map <leader>s <Action>(SelectInProjectView)
map <S-Space> <Action>(GotoNextError)

map <leader>vim :e ~\.ideavimrc<CR>
map <leader>r   <Action>(IdeaVim.ReloadVimRc.reload)


""" basic movement
nnoremap <Enter> i<Enter><ESC>
nnoremap <Home> ^
nnoremap <C-Home> 0
nnoremap <End> $
nnoremap <C-End> $
nnoremap <Backspace> dh

inoremap <C-Home> <Home>
inoremap <C-End> <End>

""" basic selection
nnoremap <S-Up> vk
nnoremap <S-Down> vj
nnoremap <S-Up> vk
nnoremap <S-Down> vj
nnoremap <S-Home> v^

inoremap <S-Up> <Esc>vk
inoremap <S-Down> <Esc>vj
inoremap <S-Up> <Esc>vk
inoremap <S-Down> <Esc>vj
inoremap <S-Home> <Esc>v^


vnoremap <S-Up> k
vnoremap <S-Down> j
vnoremap <S-Up> k
vnoremap <S-Down> j
vnoremap <S-Home> ^
""" Easy Motion ----------------------------------
set easymotion
let g:EasyMotion_do_mapping = 0
""" forward
map fl <Plug>(easymotion-w)
map f<Right> <Plug>(easymotion-w)
""" backward
map fj <Plug>(easymotion-b)
map f<Left> <Plug>(easymotion-b)
""" line-jumping
map fh <Plug>(easymotion-bd-jk)
map f<Home> <Plug>(easymotion-bd-jk)
map f<End> <Plug>(easymotion-bd-jk)
map fç <Plug>(easymotion-bd-jk)
""" free-jump
map ff <Plug>(easymotion-s)
""" End

sethandler <ESC> i:vim
sethandler n:vim i:ide
sethandler <C-Up> i-n:ide
sethandler <C-Down> i:ide
