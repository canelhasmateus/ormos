""" Map leader to space ---------------------
let mapleader=" "

""" Plugins  --------------------------------
set surround
set multiple-cursors
set commentary
set argtextobj
set easymotion
set textobj-entire
set ReplaceWithRegister

""" Plugin settings -------------------------
let g:argtextobj_pairs="[:],(:),<:>"

""" Common settings -------------------------
set showmode
set so=5
set incsearch
set nu
set visualbell
set noerrorbells
set relativenumber
set number

""" Idea specific settings ------------------

set ideajoin
set ideastatusicon=gray
set idearefactormode=keep


""" Mappings --------------------------------
map rn <Action>(RenameElement)
map <leader>c <Action>(Stop)
map <leader>z <Action>(ToggleDistractionFreeMode)



map <leader>s <Action>(SelectInProjectView)
map <S-Space> <Action>(GotoNextError)
map <leader>h <Action>(Vcs.ShowTabbedFileHistory)

map <leader>o <Action>(FileStructurePopup)
map <leader>f <Action>(AceWordStartAction)
""" map <leader>fl <Action>(AceWordBackwardsAction)
""" map <leader>l <Action>(AceWordBackwardsAction)

map <leader>vim :e ~\.ideavimrc<CR>
map <leader>r   <Action>(IdeaVim.ReloadVimRc.reload)

nnoremap <C-Home> g0
nnoremap <Home> g^
nnoremap <End> g_
nnoremap <C-End> g$
map <Backspace> dh
unmap s

let @u='di[hhpdf]'
